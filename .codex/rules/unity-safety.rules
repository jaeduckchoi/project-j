# Unity 프로젝트에서는 변경 유실이나 대량 삭제로 이어지는 명령을
# 프로젝트 레벨에서 한 번 더 제어한다.
#
# 읽기 범위 제한은 .codex/config.toml의 project-j-read-scope
# permission profile이 담당한다. 이 파일은 샌드박스 밖 명령 승인
# 정책만 다룬다.

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "기존 변경을 잃을 수 있다. 필요한 경우 변경 범위를 직접 검토하고 사용자가 명시적으로 승인한 절차로만 진행한다.",
    match = [
        "git reset --hard",
        "git reset --hard HEAD~1",
    ],
)

prefix_rule(
    pattern = ["git", "checkout", "--"],
    decision = "forbidden",
    justification = "작업 파일을 덮어쓸 수 있다. apply_patch나 수동 복구 경로를 먼저 사용한다.",
    match = [
        "git checkout -- Assets/Scripts/UI/UIManager.cs",
    ],
)

prefix_rule(
    pattern = ["git", "clean", "-fd"],
    decision = "prompt",
    justification = "Unity 프로젝트의 untracked 산출물을 지울 수 있으므로 범위를 확인한 뒤 실행한다.",
    match = [
        "git clean -fd",
        "git clean -fd Assets/TempGenerated",
    ],
)

prefix_rule(
    pattern = ["git", "clean", "-fdx"],
    decision = "forbidden",
    justification = "Unity 캐시와 로컬 산출물을 대량 삭제한다. 저장소 정리가 필요하면 사용자가 직접 범위를 확인한 뒤 진행한다.",
    match = [
        "git clean -fdx",
        "git clean -fdx Library Temp",
    ],
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "원격 반영 전에는 브랜치와 변경 범위를 마지막으로 확인한다.",
    match = [
        "git push",
        "git push origin main",
        "git push --set-upstream origin codex/unity-safety",
    ],
)
